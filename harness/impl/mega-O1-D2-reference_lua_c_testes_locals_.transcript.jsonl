djust_results(nresults);\n1792\t    Ok(LuaStatus::Ok)\n1793\t}\n1794\t\n1795\t// C: LUA_API int lua_load (lua_State *L, lua_Reader reader, void *data,\n1796\t//                          const char *chunkname, const char *mode)\n1797\t// PORT NOTE: lua_Reader (void* callback) is replaced by Box<dyn FnMut>; mode\n1798\t// is &[u8].\n1799\tpub fn load(\n1800\t    state: &mut LuaState,\n1801\t    reader: Box<dyn FnMut() -> Option<Vec<u8>>>,\n1802\t    chunkname: Option<&[u8]>,\n1803\t    mode: Option<&[u8]>,\n1804\t) -> Result<LuaStatus, LuaError> {\n1805\t    let name = chunkname.unwrap_or(b\"?\");\n1806\t    // C: luaZ_init(L, &z, reader, data); status = luaD_protectedparser(L, &z, chunkname, mode);\n1807\t    let z = crate::zio::ZIO::new(reader);\n1808\t    let status = state.protected_parser(z, name, mode);\n1809\t    if status == LuaStatus::Ok {\n1810\t        // C: LClosure *f = clLvalue(s2v(L->top.p - 1));\n1811\t        // C: if (f->nupvalues >= 1) { set global table as 1st upvalue }\n1812\t        let top = state.top_idx();\n1813\t        let func_val = state.get_at(top - 1);\n1814\t        if let LuaValue::Function(LuaClosure::Lua(lcl)) = func_val {\n1815\t            if !lcl.upvals.is_empty() {\n1816\t                // C: const TValue *gt = getGtable(L); setobj(L, f->upvals[0]->v.p, gt);\n1817\t                let gt = get_global_table(state);\n1818\t                let uv = state.new_upval_closed(gt);\n1819\t                lcl.set_upval(0, uv);\n1820\t            }\n1821\t        }\n1822\t    }\n1823\t    Ok(status)\n1824\t}\n1825\t\n1826\t// C: LUA_API int lua_dump (lua_State *L, lua_Writer writer, void *data, int strip)\n1827\tpub fn dump(\n1828\t    state: &LuaState,\n1829\t    writer: &mut dyn FnMut(&[u8]) -> Result<(), LuaError>,\n1830\t    strip: bool,\n1831\t) -> Result<bool, LuaError> {\n1832\t    // C: api_checknelems(L, 1); o = s2v(L->top.p - 1);"}]},"parent_tool_use_id":null,"session_id":"344478c4-3c7e-479a-bcbc-1e8f8efa488d","uuid":"c5b4e1d4-e5