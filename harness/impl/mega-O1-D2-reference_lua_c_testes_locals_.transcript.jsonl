{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AXj8fGH5v4sFiAk5iicvP5","type":"tool_result","content":"879\t// ── pcall ─────────────────────────────────────────────────────────────────────\n880\t\n881\t/// Protected call: returns true + results on success, or false + error on\n882\t/// failure.\n883\t///\n884\t/// C: `static int luaB_pcall(lua_State *L)`\n885\tpub(crate) fn pcall_fn(state: &mut LuaState) -> Result<usize, LuaError> {\n886\t    // C: luaL_checkany(L, 1);\n887\t    state.check_arg_any(1)?;\n888\t    // C: lua_pushboolean(L, 1); lua_insert(L, 1);\n889\t    // Stack before: [f, a1, …, aN]\n890\t    // Stack after:  [true, f, a1, …, aN]\n891\t    state.push(LuaValue::Bool(true));\n892\t    state.insert(1);\n893\t    // C: status = lua_pcallk(L, lua_gettop(L) - 2, LUA_MULTRET, 0, 0, finishpcall);\n894\t    // nargs = gettop - 2 (subtract the sentinel `true` and the function).\n895\t    let nargs = state.top() as i32 - 2;\n896\t    // TODO(port): lua_pcallk continuation (finishpcall) stubbed — coroutines Phase E.\n897\t    let ok = match state.protected_call(nargs, LUA_MULTRET, 0) {\n898\t        Ok(()) => true,\n899\t        Err(e) => {\n900\t            state.push(e.into_value());\n901\t            false\n902\t        }\n903\t    };\n904\t    // C: return finishpcall(L, status, 0);\n905\t    finish_pcall(state, ok, 0)\n906\t}\n907\t\n908\t// ── xpcall ────────────────────────────────────────────────────────────────────\n909\t\n910\t/// Protected call with a separate error-handler function.\n911\t///\n912\t/// C: `static int luaB_xpcall(lua_State *L)`\n913\tpub(crate) fn xpcall_fn(state: &mut LuaState) -> Result<usize, LuaError> {\n914\t    // C: int n = lua_gettop(L);\n915\t    let n = state.top() as i32;\n916\t    // C: luaL_checktype(L, 2, LUA_TFUNCTION);  /* check error function */\n917\t    state.check_arg_type(2, LuaType::Function)?;\n918\t    // C: lua_pushboolean(L, 1); lua_pushvalue(L, 1); lua_rotate(L, 3, 2);\n919\t    // Stack before rotate: [f, err, a1, …, aN, true, f]\n920\t    // Stack after rotate:  [f, err, true, f, a1, …, aN]\n921\t    state.push(LuaValue::Bool(true));\n922\t    state.push_copy(1)?;\n923\t    state.rotate(3, 2);\n924\t    // C: status = lua_pcallk(L, n - 2, LUA_MULTRET, 2, 2, finishpcall);\n925\t    // errfunc is at stack index 2; extra=2 means finishpcall skips 2 values.\n926\t    // TODO(port): lua_pcallk continuation (finishpcall) stubbed — coroutines Phase E.\n927\t    let ok = match state.protected_call(n - 2, LUA_MULTRET, 2) {\n928\t        Ok(()) => true,\n929\t        Err(e) => {\n930\t            state.push(e.into_value());\n931\t            false\n932\t        }\n933\t    };\n934\t    // C: return finishpcall(L, status, 2);\n935\t    finish_pcall(state, ok, 2)\n936\t}\n937\t\n938\t// ── tostring ──────────────────────────────────────────────────────────────────"}]},"parent_tool_use_id":null,"session_id":"344478c4-3c7e-479a-bcbc-1e8f8efa488d","uuid":"b94e4dbf-332c-4b1f-ad47-729d312cb8c5","timestamp":"2026-05-19T03:06:10.514Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ianmclaughlin/PycharmProjects/rustExperiments/lua-rs-port/crates/lua-stdlib/src/base.rs","content":"// ── pcall ─────────────────────────────────────────────────────────────────────\n\n/// Protected call: returns true + results on success, or false + error on\n/// failure.\n///\n/// C: `static int luaB_pcall(lua_State *L)`\npub(crate) fn pcall_fn(state: &mut LuaState) -> Result<usize, LuaError> {\n    // C: luaL_checkany(L, 1);\n    state.check_arg_any(1)?;\n    // C: lua_pushboolean(L, 1); lua_insert(L, 1);\n    // Stack before: [f, a1, …, aN]\n    // Stack after:  [true, f, a1, …, aN]\n    state.push(LuaValue::Bool(true));\n    state.insert(1);\n    // C: status = lua_pcallk(L, lua_gettop(L) - 2, LUA_MULTRET, 0, 0, finishpcall);\n    // nargs = gettop - 2 (subtract the sentinel `true` and the function).\n    let nargs = state.top() as i32 - 2;\n    // TODO(port): lua_pcallk continuation (finishpcall) stubbed — coroutines Phase E.\n    let ok = match state.protected_call(nargs, LUA_MULTRET, 0) {\n        Ok(()) => true,\n        Err(e) => {\n            state.push(e.into_value());\n            false\n        }\n    };\n    // C: return finishpcall(L, status, 0);\n    finish_pcall(state, ok, 0)\n}\n\n// ── xpcall ────────────────────────────────────────────────────────────────────\n\n/// Protected call with a separate error-handler function.\n///\n/// C: `static int luaB_xpcall(lua_State *L)`\npub(crate) fn xpcall_fn(state: &mut LuaState) -> Result<usize, LuaError> {\n    // C: int n = lua_gettop(L);\n    let n = state.top() as i32;\n    // C: luaL_checktype(L, 2, LUA_TFUNCTION);  /* check error function */\n    state.check_arg_type(2, LuaType::Function)?;\n    // C: lua_pushboolean(L, 1); lua_pushvalue(L, 1); lua_rotate(L, 3, 2);\n    // Stack before rotate: [f, err, a1, …, aN, true, f]\n    // Stack after rotate:  [f, err, true, f, a1, …, aN]\n    state.push(LuaValue::Bool(true));\n    state.push_copy(1)?;\n    state.rotate(3, 2);\n    // C: status = lua_pcallk(L, n - 2, LUA_MULTRET, 2, 2, finishpcall);\n    // errfunc is at stack index 2; extra=2 means finishpcall skips 2 values.\n    // TODO(port): lua_pcallk continuation (finishpcall) stubbed — coroutines Phase E.\n    let ok = match state.protected_call(n - 2, LUA_MULTRET, 2) {\n        Ok(()) => true,\n        Err(e) => {\n            state.push(e.into_value());\n            false\n        }\n    };\n    // C: return finishpcall(L, status, 2);\n    finish_pcall(state, ok, 2)\n}\n\n// ── tostring ──────────────────────────────────────────────────────────────────","numLines":60,"startLine":879,"totalLines":1028}}}
