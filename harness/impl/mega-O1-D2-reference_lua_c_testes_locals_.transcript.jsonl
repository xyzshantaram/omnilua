{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VznrczVazAsTFfCFAaPu2Z","type":"tool_result","content":"1\t//! Coroutine library — port of `lcorolib.c`.\n2\t//!\n3\t//! Provides the `coroutine.*` standard-library table: `create`, `resume`,\n4\t//! `running`, `status`, `wrap`, `yield`, `isyieldable`, and `close`.\n5\t//!\n6\t//! # Phase A–D stub notice\n7\t//!\n8\t//! Every function that requires actual coroutine execution (`resume`, `yield`,\n9\t//! cross-thread `xmove`, `new_thread`, `close_thread`) is **unimplemented** and\n10\t//! will panic at runtime.  The argument-checking and result-packaging logic is\n11\t//! translated faithfully so that Phase E can drop in the real implementations\n12\t//! without restructuring.  Phase E wires real stackful coroutines via\n13\t//! `corosensei`.  See PORTING.md §2 #6.\n14\t//!\n15\t//! Translated from: `reference/lua-5.4.7/src/lcorolib.c` (210 lines, 12 functions)\n16\t//! Target crate: `lua-stdlib`\n17\t\n18\t// TODO(port): LuaState, GcRef<LuaState>, LuaStatus, and related types live in\n19\t// lua-vm / lua-types; all unresolved imports will be fixed in Phase B.\n20\tuse lua_types::{\n21\t    closure::LuaClosure,\n22\t    error::LuaError,\n23\t    value::LuaValue,\n24\t    LuaType,\n25\t    LuaStatus,\n26\t    gc::GcRef,\n27\t};\n28\tuse crate::state_stub::{LuaState, LuaStateStubExt as _, lua_CFunction, upvalue_index, CompareOp, LuaDebug};\n29\t\n30\t// ── Coroutine status codes ────────────────────────────────────────────────────\n31\t\n32\t// C: #define COS_RUN   0\n33\t// C: #define COS_DEAD  1\n34\t// C: #define COS_YIELD 2\n35\t// C: #define COS_NORM  3\n36\t\n37\t/// Coroutine is the currently running thread.\n38\tconst COS_RUN: i32 = 0;\n39\t\n40\t/// Coroutine has finished execution or encountered an error.\n41\tconst COS_DEAD: i32 = 1;\n42\t\n43\t/// Coroutine is suspended — either yielded or not yet started.\n44\tconst COS_YIELD: i32 = 2;\n45\t\n46\t/// Coroutine is normal — it resumed another coroutine and is waiting.\n47\tconst COS_NORM: i32 = 3;\n48\t\n49\t/// Human-readable status strings indexed by the `COS_*` constants above.\n50\t/// Pushed onto the Lua stack as byte strings.\n51\t///\n52\t/// C: `static const char *const statname[] = {\"running\",\"dead\",\"suspended\",\"normal\"};`\n53\tconst STAT_NAMES: [&[u8]; 4] = [b\"running\", b\"dead\", b\"suspended\", b\"normal\"];\n54\t\n55\t// ── Registration table ────────────────────────────────────────────────────────\n56\t\n57\t/// Registration table for the `coroutine` standard library.\n58\t///\n59\t/// C: `static const luaL_Reg co_funcs[]`\n60\t///\n61\t/// Each entry is `(name_bytes, function_pointer)`. Phase B resolves\n62\t/// `lua_CFunction` to the canonical type alias from `lua-types`.\n63\tpub const CO_FUNCS: &[(&[u8], lua_CFunction)] = &[\n64\t    (b\"create\",      co_create),\n65\t    (b\"resume\",      co_resume),\n66\t    (b\"running\",     co_running),\n67\t    (b\"status\",      co_status),\n68\t    (b\"wrap\",        co_wrap),\n69\t    (b\"yield\",       co_yield),\n70\t    (b\"isyieldable\", co_isyieldable),\n71\t    (b\"close\",       co_close),\n72\t];\n73\t\n74\t// ── Internal helpers ──────────────────────────────────────────────────────────\n75\t\n76\t/// Retrieves the coroutine thread at stack index 1, raising a type error if\n77\t/// the argument is absent or not a thread.\n78\t///\n79\t/// C: `static lua_State *getco(lua_State *L)`\n80\tfn get_co(state: &mut LuaState) -> Result<GcRef<lua_types::value::LuaThread>, LuaError> {\n81\t    let co = state.to_thread(1);\n82\t    if co.is_none() {\n83\t        let got = state.arg(1);\n84\t        return Err(LuaError::type_arg_error(1, \"thread\", &got));\n85\t    }\n86\t    Ok(co.expect(\"checked above\"))\n87\t}\n88\t\n89\t/// Returns one of the `COS_*` status codes describing `co` relative to the\n90\t/// calling thread `state`. Mirrors `auxstatus` in `lcorolib.c` exactly,\n91\t/// reading the target coroutine's `status`, call-frame depth, and stack\n92\t/// top through `GlobalState::threads`.\n93\t///\n94\t/// The main thread (id 0) is never stored in the registry, so a value\n95\t/// pointing at it is always \"running\" when it is the current thread.\n96\t/// Phase E-1 cannot resume coroutines, so any registry-resident thread\n97\t/// is either suspended (initial state, function still on stack) or dead\n98\t/// (empty stack).\n99\t///\n100\t/// C: `static int auxstatus(lua_State *L, lua_State *co)`\n101\tfn aux_status(state: &mut LuaState, co: &GcRef<lua_types::value::LuaThread>) -> i32 {\n102\t    let co_id = co.id;\n103\t    let g = state.global();\n104\t    if co_id == g.current_thread_id {\n105\t        return COS_RUN;\n106\t    }\n107\t    let entry = match g.threads.get(&co_id) {\n108\t        Some(e) => e,\n109\t        None => return COS_DEAD,\n110\t    };\n111\t    let co_state: &lua_vm::state::LuaState = &entry.state;\n112\t    let raw_status = co_state.status;\n113\t    if raw_status == LuaStatus::Yield as u8 {\n114\t        return COS_YIELD;\n115\t    }\n116\t    if raw_status != LuaStatus::Ok as u8 {\n117\t        return COS_DEAD;\n118\t    }\n119\t    let has_frames = co_state.ci.as_usize() > 0;\n120\t    if has_frames {\n121\t        return COS_NORM;\n122\t    }\n123\t    let ci_func = co_state.call_info[0].func.0;\n124\t    let top = co_state.top.0;\n125\t    let lua_gettop = top as i64 - ci_func as i64 - 1;\n126\t    if lua_gettop == 0 {\n127\t        COS_DEAD\n128\t    } else {\n129\t        COS_YIELD\n130\t    }\n131\t}\n132\t\n133\t/// Transfers `narg` arguments from `state` to `co`, resumes the coroutine,\n134\t/// then transfers results (or error message) back to `state`.\n135\t///\n136\t/// Returns the number of result values (≥ 0) on success, or `-1` on error\n137\t/// with the error object left on top of `state`'s stack.\n138\t///\n139\t/// C: `static int auxresume(lua_State *L, lua_State *co, int narg)`\n140\tfn aux_resume(state: &mut LuaState, _co: GcRef<lua_types::value::LuaThread>, _narg: i32) -> i32 {\n141\t    // Phase A–D stub: real cross-thread resume needs corosensei runtime\n142\t    // support (PORTING.md §2 #6 — Phase E).  Emulate C's `auxresume` error\n143\t    // path: push a string error object onto the caller's stack and return\n144\t    // -1.  `co_resume` packages this as `(false, msg)` and `aux_wrap`\n145\t    // re-raises it as a Lua error, matching C-Lua semantics on a coroutine\n146\t    // that cannot run.  Phase E will replace this body with the full\n147\t    // checkstack / xmove / lua_resume / xmove sequence.\n148\t    let msg_bytes: &[u8] = b\"not yet implemented: coroutines (Phase E)\";\n149\t    match state.intern_str(msg_bytes) {\n150\t        Ok(s) => state.push(LuaValue::Str(s)),\n151\t        Err(_) => state.push(LuaValue::Nil),\n152\t    }\n153\t    -1\n154\t}\n155\t\n156\t// ── Public library functions ──────────────────────────────────────────────────\n157\t\n158\t/// `coroutine.resume(co [, val1, ...])` — attempt to resume coroutine `co`.\n159\t///\n160\t/// On success pushes `true` followed by all values yielded or returned by `co`.\n161\t/// On failure pushes `false` followed by the error object.\n162\t///\n163\t/// C: `static int luaB_coresume(lua_State *L)`\n164\tpub fn co_resume(state: &mut LuaState) -> Result<usize, LuaError> {\n165\t    // C: lua_State *co = getco(L);\n166\t    let co = get_co(state)?;\n167\t    // C: r = auxresume(L, co, lua_gettop(L) - 1);\n168\t    // PORT NOTE: lua_gettop returns the argument count; -1 excludes the coroutine\n169\t    // itself which sits at index 1.\n170\t    let narg = state.get_top() - 1;\n171\t    let r = aux_resume(state, co, narg);\n172\t    if r < 0 {\n173\t        // C: lua_pushboolean(L, 0); lua_insert(L, -2); return 2;\n174\t        state.push(LuaValue::Bool(false));\n175\t        state.insert(-2);\n176\t        Ok(2)\n177\t    } else {\n178\t        // C: lua_pushboolean(L, 1); lua_insert(L, -(r + 1)); return r + 1;\n179\t        state.push(LuaValue::Bool(true));\n180\t        state.insert(-(r + 1));\n181\t        Ok((r + 1) as usize)\n182\t    }\n183\t}\n184\t\n185\t/// Closure body installed by `coroutine.wrap`. The wrapped function is\n186\t/// stored in upvalue slot 1.\n187\t///\n188\t/// C: `static int luaB_auxwrap(lua_State *L)`\n189\t///\n190\t/// Phase A–D emulation: on the first call, runs the entire wrapped function\n191\t/// with a yield buffer installed, collects all yield batches (one per\n192\t/// `coroutine.yield(...)` call) and the function's final return values as\n193\t/// the last batch, stores them in `GlobalState::wrap_iter_state` keyed by\n194\t/// this closure's identity, and returns the first batch. Subsequent calls\n195\t/// dispense one batch per call (matching real coroutine semantics) until the\n196\t/// final-return batch is returned, at which point the entry is removed.\n197\t/// Phase E replaces this with the full cross-thread `auxresume` sequence\n198\t/// once stackful coroutines land.\n199\tfn aux_wrap(state: &mut LuaState) -> Result<usize, LuaError> {\n200\t    let ci_func = state.current_call_info().func;\n201\t    let func_val = state.get_at(ci_func);\n202\t    let cache_key = match &func_val {\n203\t        LuaValue::Function(LuaClosure::C(ccl)) => ccl.identity(),\n204\t        _ => {\n205\t            return Err(LuaError::runtime(format_args!(\n206\t                \"coroutine.wrap: aux_wrap called on non-C-closure\"\n207\t            )))\n208\t        }\n209\t    };\n210\t    drop(func_val);\n211\t\n212\t    enum Dispense {\n213\t        Batch(Vec<LuaValue>),\n214\t        Drain(Option<LuaError>),\n215\t    }\n216\t\n217\t    let maybe_next: Option<Dispense> = {\n218\t        let mut g = state.global_mut();\n219\t        g.wrap_iter_state.get_mut(&cache_key).map(|(batches, idx, pending_err)| {\n220\t            if *idx < batches.len() {\n221\t                let batch = batches[*idx].clone();\n222\t                *idx += 1;\n223\t                Dispense::Batch(batch)\n224\t            } else {\n225\t                Dispense::Drain(pending_err.take())\n226\t            }\n227\t        })\n228\t    };\n229\t\n230\t    match maybe_next {\n231\t        Some(Dispense::Batch(batch)) => {\n232\t            let n = batch.len();\n233\t            for v in batch {\n234\t                state.push(v);\n235\t            }\n236\t            return Ok(n);\n237\t        }\n238\t        Some(Dispense::Drain(pending_err)) => {\n239\t            state.global_mut().wrap_iter_state.remove(&cache_key);\n240\t            if let Some(err) = pending_err {\n241\t                return Err(err);\n242\t            }\n243\t            return Ok(0);\n244\t        }\n245\t        None => {}\n246\t    }\n247\t\n248\t    // First call: run the wrapped function with a yield buffer active.\n249\t    let nargs = state.get_top();\n250\t    let func = state.value_at(upvalue_index(1));\n251\t    state.push(func);\n252\t    if nargs > 0 {\n253\t        state.insert(1)?;\n254\t    }\n255\t    state.push_yield_buffer();\n256\t    // Use LUA_MULTRET (-1) so the function's final return values reach the stack.\n257\t    let call_result = state.call(nargs, -1);\n258\t\n259\t    // If the call succeeded, capture its final return values as the closing\n260\t    // batch.  On error we discard whatever residue is on the stack and defer\n261\t    // the error to fire after all already-buffered yield batches have been\n262\t    // dispensed (matches C-Lua: yields happen before the error surfaces).\n263\t    let (mut batches, pending_err) = match call_result {\n264\t        Ok(_) => {\n265\t            let nret = state.get_top() as i32;\n266\t            let final_batch: Vec<LuaValue> =\n267\t                (1..=nret).map(|i| state.value_at(i)).collect();\n268\t            let mut batches = state.pop_yield_buffer();\n269\t            batches.push(final_batch);\n270\t            (batches, None)\n271\t        }\n272\t        Err(e) => {\n273\t            let batches = state.pop_yield_buffer();\n274\t            (batches, Some(e))\n275\t        }\n276\t    };\n277\t\n278\t    // Clear residual stack values; we'll push the first batch instead.\n279\t    lua_vm::api::set_top(state, 0)?;\n280\t\n281\t    if batches.is_empty() {\n282\t        if let Some(err) = pending_err {\n283\t            return Err(err);\n284\t        }\n285\t        return Ok(0);\n286\t    }\n287\t\n288\t    // Remove and return the first batch; save the rest plus any pending\n289\t    // error for subsequent calls.\n290\t    let first = batches.remove(0);\n291\t    let first_n = first.len();\n292\t\n293\t    if !batches.is_empty() || pending_err.is_some() {\n294\t        state\n295\t            .global_mut()\n296\t            .wrap_iter_state\n297\t            .insert(cache_key, (batches, 0, pending_err));\n298\t    }\n299\t\n300\t    for v in first {\n301\t        state.push(v);\n302\t    }\n303\t    Ok(first_n)\n304\t}\n305\t\n306\t/// `coroutine.create(f)` — create a new coroutine that will run function `f`.\n307\t///\n308\t/// Pushes the new thread value and returns 1.\n309\t///\n310\t/// Phase E-1: allocates a real `LuaState` registered in\n311\t/// `GlobalState::threads`, with `f` staged on the new thread's stack so\n312\t/// `coroutine.status` reports `\"suspended\"`. The full `xmove` from the\n313\t/// caller's stack arrives in slice 02b; for this slice the body is\n314\t/// cloned via `value_at(1)`, which has the same net stack effect since\n315\t/// `lua_newthread` in C also leaves only the thread value on the\n316\t/// caller's stack.\n317\t///\n318\t/// C: `static int luaB_cocreate(lua_State *L)`\n319\tpub fn co_create(state: &mut LuaState) -> Result<usize, LuaError> {\n320\t    state.check_arg_type(1, LuaType::Function)?;\n321\t    let body = state.value_at(1);\n322\t    let _nl = state.new_thread(Some(body))?;\n323\t    Ok(1)\n324\t}\n325\t\n326\t/// `coroutine.wrap(f)` — create a coroutine and return a resuming function.\n327\t///\n328\t/// The returned function, when called, resumes the coroutine as if by\n329\t/// `coroutine.resume`, but raises an error rather than returning `false`.\n330\t///\n331\t/// C: `static int luaB_cowrap(lua_State *L)`\n332\t///\n333\t/// Phase A–D emulation: captures `f` as upvalue 1 of `aux_wrap`. Each\n334\t/// call to the returned function forwards directly to `f` with the same\n335\t/// args. Phase E will replace this with the real `luaB_cocreate` +\n336\t/// `auxresume` sequence once stackful coroutines land.\n337\tpub fn co_wrap(state: &mut LuaState) -> Result<usize, LuaError> {\n338\t    state.check_arg_type(1, LuaType::Function)?;\n339\t    state.push_value_at(1)?;\n340\t    state.push_cclosure(aux_wrap, 1)?;\n341\t    Ok(1)\n342\t}\n343\t\n344\t/// `coroutine.yield([...])` — suspend the running coroutine.\n345\t///\n346\t/// All arguments are passed back as results of the corresponding `resume`.\n347\t///\n348\t/// C: `static int luaB_yield(lua_State *L)`\n349\t/// → `return lua_yield(L, lua_gettop(L));`\n350\t/// → `lua_yield(L,n)` is `lua_yieldk(L, n, 0, NULL)` (lua.h:316)\n351\t///\n352\t/// Phase A–D buffering-emulation hook: if `aux_wrap` has installed a yield\n353\t/// buffer on the LuaState (signalling that a `coroutine.wrap` body is\n354\t/// running synchronously on the main thread), append the arguments into\n355\t/// that buffer and return 0 values without suspending. The wrapped\n356\t/// function continues to run; `aux_wrap` dispenses the buffered values one\n357\t/// per call. If no buffer is active we fall through to the faithful\n358\t/// `lua_yieldk` translation, which on the main thread surfaces the C-Lua\n359\t/// \"attempt to yield from outside a coroutine\" error.\n360\tpub fn co_yield(state: &mut LuaState) -> Result<usize, LuaError> {\n361\t    if state.has_yield_buffer() {\n362\t        let n = state.get_top();\n363\t        let batch: Vec<LuaValue> = (1..=n).map(|i| state.value_at(i)).collect();\n364\t        state.yield_buffer_push_batch(batch);\n365\t        return Ok(0);\n366\t    }\n367\t    let n = state.get_top();\n368\t    let r = lua_vm::do_::lua_yieldk(state, n, 0, None)?;\n369\t    Ok(r as usize)\n370\t}\n371\t\n372\t/// `coroutine.status(co)` — return a string describing `co`'s current status.\n373\t///\n374\t/// Returns one of `\"running\"`, `\"dead\"`, `\"suspended\"`, or `\"normal\"`.\n375\t///\n376\t/// C: `static int luaB_costatus(lua_State *L)`\n377\tpub fn co_status(state: &mut LuaState) -> Result<usize, LuaError> {\n378\t    // C: lua_State *co = getco(L);\n379\t    let co = get_co(state)?;\n380\t    // C: lua_pushstring(L, statname[auxstatus(L, co)]);\n381\t    let idx = aux_status(state, &co) as usize;\n382\t    let name: &[u8] = STAT_NAMES[idx];\n383\t    let interned = state.intern_str(name)?;\n384\t    state.push(LuaValue::Str(interned));\n385\t    Ok(1)\n386\t}\n387\t\n388\t/// `coroutine.isyieldable([co])` — test whether a coroutine (default: current)\n389\t/// is in a yieldable state.\n390\t///\n391\t/// C: `static int luaB_yieldable(lua_State *L)`\n392\tpub fn co_isyieldable(state: &mut LuaState) -> Result<usize, LuaError> {\n393\t    let is_yieldable = if matches!(state.type_at(1), LuaType::None) {\n394\t        state.is_yieldable()\n395\t    } else {\n396\t        let co = get_co(state)?;\n397\t        let co_id = co.id;\n398\t        let g = state.global();\n399\t        if co_id == g.main_thread_id {\n400\t            false\n401\t        } else {\n402\t            let entry = g\n403\t                .threads\n404\t                .get(&co_id)\n405\t                .expect(\"thread value carries an id that must resolve in GlobalState::threads\");\n406\t            entry.state.is_yieldable()\n407\t        }\n408\t    };\n409\t    state.push(LuaValue::Bool(is_yieldable));\n410\t    Ok(1)\n411\t}\n412\t\n413\t/// `coroutine.running()` — return the current coroutine plus a boolean.\n414\t///\n415\t/// The boolean is `true` when the current coroutine is the main thread.\n416\t///\n417\t/// C: `static int luaB_corunning(lua_State *L)`\n418\tpub fn co_running(state: &mut LuaState) -> Result<usize, LuaError> {\n419\t    // C: int ismain = lua_pushthread(L);\n420\t    // TODO(port): push_thread pushes a Thread value for the current LuaState and\n421\t    // returns true iff it is the main thread; Phase B wire-up needed.\n422\t    let is_main = state.push_thread()?;\n423\t    // C: lua_pushboolean(L, ismain);\n424\t    state.push(LuaValue::Bool(is_main));\n425\t    Ok(2)\n426\t}\n427\t\n428\t/// `coroutine.close(co)` — close a dead or suspended coroutine.\n429\t///\n430\t/// Phase E-1 skeleton: the running/normal-rejection branch matches the\n431\t/// final C-Lua behavior and lands here. Closing a suspended/dead\n432\t/// coroutine requires running to-be-closed variables and resetting the\n433\t/// thread; that machinery lands in slice 02d. Until then this returns\n434\t/// an error rather than silently dropping the work.\n435\t///\n436\t/// C: `static int luaB_close(lua_State *L)`\n437\tpub fn co_close(state: &mut LuaState) -> Result<usize, LuaError> {\n438\t    let co = get_co(state)?;\n439\t    let status = aux_status(state, &co);\n440\t    match status {\n441\t        COS_RUN | COS_NORM => {\n442\t            let name = if status == COS_RUN { \"running\" } else { \"normal\" };\n443\t            Err(LuaError::runtime(format_args!(\n444\t                \"cannot close a {} coroutine\",\n445\t                name\n446\t            )))\n447\t        }\n448\t        _ => Err(LuaError::runtime(format_args!(\n449\t            \"coroutine.close not yet implemented for suspended/dead coroutines (Phase E-2d)\"\n450\t        ))),\n451\t    }\n452\t}\n453\t\n454\t// ── Module entry point ────────────────────────────────────────────────────────\n455\t\n456\t/// Opens the `coroutine` standard library by pushing a new table containing\n457\t/// all `coroutine.*` functions.\n458\t///\n459\t/// C: `LUAMOD_API int luaopen_coroutine(lua_State *L)` — `LUAMOD_API` → `pub`.\n460\tpub fn open_coroutine(state: &mut LuaState) -> Result<usize, LuaError> {\n461\t    // C: luaL_newlib(L, co_funcs);\n462\t    // TODO(port): state.new_lib(CO_FUNCS) creates a table from the registration\n463\t    // slice and leaves it on the stack; Phase B wire-up needed.\n464\t    state.new_lib(CO_FUNCS)?;\n465\t    Ok(1)\n466\t}\n467\t\n468\t// ──────────────────────────────────────────────────────────────────────────────\n469\t// PORT STATUS\n470\t//   source:        src/lcorolib.c  (210 lines, 12 functions)\n471\t//   target_crate:  lua-stdlib\n472\t//   confidence:    medium\n473\t//   todos:         21\n474\t//   port_notes:    2\n475\t//   unsafe_blocks: 0\n476\t//   notes:         All coroutine execution primitives (resume, yield, xmove,\n477\t//                  new_thread, close_thread) are Phase E stubs that panic.\n478\t//                  Argument-checking / result-packaging logic is faithfully\n479\t//                  translated so Phase E can drop in real implementations.\n480\t//                  The CO_FUNCS table type references lua_CFunction which is\n481\t//                  resolved in Phase B.  LuaState / GcRef<LuaState> / LuaStatus\n482\t//                  imports are all deferred to Phase B.\n483\t// ──────────────────────────────────────────────────────────────────────────────\n484\t"}]},"parent_tool_use_id":null,"session_id":"344478c4-3c7e-479a-bcbc-1e8f8efa488d","uuid":"22793b3b-c001-4de1-b1f1-ce3f3f01251f","timestamp":"2026-05-19T03:05:41.739Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ianmclaughlin/PycharmProjects/rustExperiments/lua-rs-port/crates/lua-stdlib/src/coro_lib.rs","content":"//! Coroutine library — port of `lcorolib.c`.\n//!\n//! Provides the `coroutine.*` standard-library table: `create`, `resume`,\n//! `running`, `status`, `wrap`, `yield`, `isyieldable`, and `close`.\n//!\n//! # Phase A–D stub notice\n//!\n//! Every function that requires actual coroutine execution (`resume`, `yield`,\n//! cross-thread `xmove`, `new_thread`, `close_thread`) is **unimplemented** and\n//! will panic at runtime.  The argument-checking and result-packaging logic is\n//! translated faithfully so that Phase E can drop in the real implementations\n//! without restructuring.  Phase E wires real stackful coroutines via\n//! `corosensei`.  See PORTING.md §2 #6.\n//!\n//! Translated from: `reference/lua-5.4.7/src/lcorolib.c` (210 lines, 12 functions)\n//! Target crate: `lua-stdlib`\n\n// TODO(port): LuaState, GcRef<LuaState>, LuaStatus, and related types live in\n// lua-vm / lua-types; all unresolved imports will be fixed in Phase B.\nuse lua_types::{\n    closure::LuaClosure,\n    error::LuaError,\n    value::LuaValue,\n    LuaType,\n    LuaStatus,\n    gc::GcRef,\n};\nuse crate::state_stub::{LuaState, LuaStateStubExt as _, lua_CFunction, upvalue_index, CompareOp, LuaDebug};\n\n// ── Coroutine status codes ────────────────────────────────────────────────────\n\n// C: #define COS_RUN   0\n// C: #define COS_DEAD  1\n// C: #define COS_YIELD 2\n// C: #define COS_NORM  3\n\n/// Coroutine is the currently running thread.\nconst COS_RUN: i32 = 0;\n\n/// Coroutine has finished execution or encountered an error.\nconst COS_DEAD: i32 = 1;\n\n/// Coroutine is suspended — either yielded or not yet started.\nconst COS_YIELD: i32 = 2;\n\n/// Coroutine is normal — it resumed another coroutine and is waiting.\nconst COS_NORM: i32 = 3;\n\n/// Human-readable status strings indexed by the `COS_*` constants above.\n/// Pushed onto the Lua stack as byte strings.\n///\n/// C: `static const char *const statname[] = {\"running\",\"dead\",\"suspended\",\"normal\"};`\nconst STAT_NAMES: [&[u8]; 4] = [b\"running\", b\"dead\", b\"suspended\", b\"normal\"];\n\n// ── Registration table ────────────────────────────────────────────────────────\n\n/// Registration table for the `coroutine` standard library.\n///\n/// C: `static const luaL_Reg co_funcs[]`\n///\n/// Each entry is `(name_bytes, function_pointer)`. Phase B resolves\n/// `lua_CFunction` to the canonical type alias from `lua-types`.\npub const CO_FUNCS: &[(&[u8], lua_CFunction)] = &[\n    (b\"create\",      co_create),\n    (b\"resume\",      co_resume),\n    (b\"running\",     co_running),\n    (b\"status\",      co_status),\n    (b\"wrap\",        co_wrap),\n    (b\"yield\",       co_yield),\n    (b\"isyieldable\", co_isyieldable),\n    (b\"close\",       co_close),\n];\n\n// ── Internal helpers ──────────────────────────────────────────────────────────\n\n/// Retrieves the coroutine thread at stack index 1, raising a type error if\n/// the argument is absent or not a thread.\n///\n/// C: `static lua_State *getco(lua_State *L)`\nfn get_co(state: &mut LuaState) -> Result<GcRef<lua_types::value::LuaThread>, LuaError> {\n    let co = state.to_thread(1);\n    if co.is_none() {\n        let got = state.arg(1);\n        return Err(LuaError::type_arg_error(1, \"thread\", &got));\n    }\n    Ok(co.expect(\"checked above\"))\n}\n\n/// Returns one of the `COS_*` status codes describing `co` relative to the\n/// calling thread `state`. Mirrors `auxstatus` in `lcorolib.c` exactly,\n/// reading the target coroutine's `status`, call-frame depth, and stack\n/// top through `GlobalState::threads`.\n///\n/// The main thread (id 0) is never stored in the registry, so a value\n/// pointing at it is always \"running\" when it is the current thread.\n/// Phase E-1 cannot resume coroutines, so any registry-resident thread\n/// is either suspended (initial state, function still on stack) or dead\n/// (empty stack).\n///\n/// C: `static int auxstatus(lua_State *L, lua_State *co)`\nfn aux_status(state: &mut LuaState, co: &GcRef<lua_types::value::LuaThread>) -> i32 {\n    let co_id = co.id;\n    let g = state.global();\n    if co_id == g.current_thread_id {\n        return COS_RUN;\n    }\n    let entry = match g.threads.get(&co_id) {\n        Some(e) => e,\n        None => return COS_DEAD,\n    };\n    let co_state: &lua_vm::state::LuaState = &entry.state;\n    let raw_status = co_state.status;\n    if raw_status == LuaStatus::Yield as u8 {\n        return COS_YIELD;\n    }\n    if raw_status != LuaStatus::Ok as u8 {\n        return COS_DEAD;\n    }\n    let has_frames = co_state.ci.as_usize() > 0;\n    if has_frames {\n        return COS_NORM;\n    }\n    let ci_func = co_state.call_info[0].func.0;\n    let top = co_state.top.0;\n    let lua_gettop = top as i64 - ci_func as i64 - 1;\n    if lua_gettop == 0 {\n        COS_DEAD\n    } else {\n        COS_YIELD\n    }\n}\n\n/// Transfers `narg` arguments from `state` to `co`, resumes the coroutine,\n/// then transfers results (or error message) back to `state`.\n///\n/// Returns the number of result values (≥ 0) on success, or `-1` on error\n/// with the error object left on top of `state`'s stack.\n///\n/// C: `static int auxresume(lua_State *L, lua_State *co, int narg)`\nfn aux_resume(state: &mut LuaState, _co: GcRef<lua_types::value::LuaThread>, _narg: i32) -> i32 {\n    // Phase A–D stub: real cross-thread resume needs corosensei runtime\n    // support (PORTING.md §2 #6 — Phase E).  Emulate C's `auxresume` error\n    // path: push a string error object onto the caller's stack and return\n    // -1.  `co_resume` packages this as `(false, msg)` and `aux_wrap`\n    // re-raises it as a Lua error, matching C-Lua semantics on a coroutine\n    // that cannot run.  Phase E will replace this body with the full\n    // checkstack / xmove / lua_resume / xmove sequence.\n    let msg_bytes: &[u8] = b\"not yet implemented: coroutines (Phase E)\";\n    match state.intern_str(msg_bytes) {\n        Ok(s) => state.push(LuaValue::Str(s)),\n        Err(_) => state.push(LuaValue::Nil),\n    }\n    -1\n}\n\n// ── Public library functions ──────────────────────────────────────────────────\n\n/// `coroutine.resume(co [, val1, ...])` — attempt to resume coroutine `co`.\n///\n/// On success pushes `true` followed by all values yielded or returned by `co`.\n/// On failure pushes `false` followed by the error object.\n///\n/// C: `static int luaB_coresume(lua_State *L)`\npub fn co_resume(state: &mut LuaState) -> Result<usize, LuaError> {\n    // C: lua_State *co = getco(L);\n    let co = get_co(state)?;\n    // C: r = auxresume(L, co, lua_gettop(L) - 1);\n    // PORT NOTE: lua_gettop returns the argument count; -1 excludes the coroutine\n    // itself which sits at index 1.\n    let narg = state.get_top() - 1;\n    let r = aux_resume(state, co, narg);\n    if r < 0 {\n        // C: lua_pushboolean(L, 0); lua_insert(L, -2); return 2;\n        state.push(LuaValue::Bool(false));\n        state.insert(-2);\n        Ok(2)\n    } else {\n        // C: lua_pushboolean(L, 1); lua_insert(L, -(r + 1)); return r + 1;\n        state.push(LuaValue::Bool(true));\n        state.insert(-(r + 1));\n        Ok((r + 1) as usize)\n    }\n}\n\n/// Closure body installed by `coroutine.wrap`. The wrapped function is\n/// stored in upvalue slot 1.\n///\n/// C: `static int luaB_auxwrap(lua_State *L)`\n///\n/// Phase A–D emulation: on the first call, runs the entire wrapped function\n/// with a yield buffer installed, collects all yield batches (one per\n/// `coroutine.yield(...)` call) and the function's final return values as\n/// the last batch, stores them in `GlobalState::wrap_iter_state` keyed by\n/// this closure's identity, and returns the first batch. Subsequent calls\n/// dispense one batch per call (matching real coroutine semantics) until the\n/// final-return batch is returned, at which point the entry is removed.\n/// Phase E replaces this with the full cross-thread `auxresume` sequence\n/// once stackful coroutines land.\nfn aux_wrap(state: &mut LuaState) -> Result<usize, LuaError> {\n    let ci_func = state.current_call_info().func;\n    let func_val = state.get_at(ci_func);\n    let cache_key = match &func_val {\n        LuaValue::Function(LuaClosure::C(ccl)) => ccl.identity(),\n        _ => {\n            return Err(LuaError::runtime(format_args!(\n                \"coroutine.wrap: aux_wrap called on non-C-closure\"\n            )))\n        }\n    };\n    drop(func_val);\n\n    enum Dispense {\n        Batch(Vec<LuaValue>),\n        Drain(Option<LuaError>),\n    }\n\n    let maybe_next: Option<Dispense> = {\n        let mut g = state.global_mut();\n        g.wrap_iter_state.get_mut(&cache_key).map(|(batches, idx, pending_err)| {\n            if *idx < batches.len() {\n                let batch = batches[*idx].clone();\n                *idx += 1;\n                Dispense::Batch(batch)\n            } else {\n                Dispense::Drain(pending_err.take())\n            }\n        })\n    };\n\n    match maybe_next {\n        Some(Dispense::Batch(batch)) => {\n            let n = batch.len();\n            for v in batch {\n                state.push(v);\n            }\n            return Ok(n);\n        }\n        Some(Dispense::Drain(pending_err)) => {\n            state.global_mut().wrap_iter_state.remove(&cache_key);\n            if let Some(err) = pending_err {\n                return Err(err);\n            }\n            return Ok(0);\n        }\n        None => {}\n    }\n\n    // First call: run the wrapped function with a yield buffer active.\n    let nargs = state.get_top();\n    let func = state.value_at(upvalue_index(1));\n    state.push(func);\n    if nargs > 0 {\n        state.insert(1)?;\n    }\n    state.push_yield_buffer();\n    // Use LUA_MULTRET (-1) so the function's final return values reach the stack.\n    let call_result = state.call(nargs, -1);\n\n    // If the call succeeded, capture its final return values as the closing\n    // batch.  On error we discard whatever residue is on the stack and defer\n    // the error to fire after all already-buffered yield batches have been\n    // dispensed (matches C-Lua: yields happen before the error surfaces).\n    let (mut batches, pending_err) = match call_result {\n        Ok(_) => {\n            let nret = state.get_top() as i32;\n            let final_batch: Vec<LuaValue> =\n                (1..=nret).map(|i| state.value_at(i)).collect();\n            let mut batches = state.pop_yield_buffer();\n            batches.push(final_batch);\n            (batches, None)\n        }\n        Err(e) => {\n            let batches = state.pop_yield_buffer();\n            (batches, Some(e))\n        }\n    };\n\n    // Clear residual stack values; we'll push the first batch instead.\n    lua_vm::api::set_top(state, 0)?;\n\n    if batches.is_empty() {\n        if let Some(err) = pending_err {\n            return Err(err);\n        }\n        return Ok(0);\n    }\n\n    // Remove and return the first batch; save the rest plus any pending\n    // error for subsequent calls.\n    let first = batches.remove(0);\n    let first_n = first.len();\n\n    if !batches.is_empty() || pending_err.is_some() {\n        state\n            .global_mut()\n            .wrap_iter_state\n            .insert(cache_key, (batches, 0, pending_err));\n    }\n\n    for v in first {\n        state.push(v);\n    }\n    Ok(first_n)\n}\n\n/// `coroutine.create(f)` — create a new coroutine that will run function `f`.\n///\n/// Pushes the new thread value and returns 1.\n///\n/// Phase E-1: allocates a real `LuaState` registered in\n/// `GlobalState::threads`, with `f` staged on the new thread's stack so\n/// `coroutine.status` reports `\"suspended\"`. The full `xmove` from the\n/// caller's stack arrives in slice 02b; for this slice the body is\n/// cloned via `value_at(1)`, which has the same net stack effect since\n/// `lua_newthread` in C also leaves only the thread value on the\n/// caller's stack.\n///\n/// C: `static int luaB_cocreate(lua_State *L)`\npub fn co_create(state: &mut LuaState) -> Result<usize, LuaError> {\n    state.check_arg_type(1, LuaType::Function)?;\n    let body = state.value_at(1);\n    let _nl = state.new_thread(Some(body))?;\n    Ok(1)\n}\n\n/// `coroutine.wrap(f)` — create a coroutine and return a resuming function.\n///\n/// The returned function, when called, resumes the coroutine as if by\n/// `coroutine.resume`, but raises an error rather than returning `false`.\n///\n/// C: `static int luaB_cowrap(lua_State *L)`\n///\n/// Phase A–D emulation: captures `f` as upvalue 1 of `aux_wrap`. Each\n/// call to the returned function forwards directly to `f` with the same\n/// args. Phase E will replace this with the real `luaB_cocreate` +\n/// `auxresume` sequence once stackful coroutines land.\npub fn co_wrap(state: &mut LuaState) -> Result<usize, LuaError> {\n    state.check_arg_type(1, LuaType::Function)?;\n    state.push_value_at(1)?;\n    state.push_cclosure(aux_wrap, 1)?;\n    Ok(1)\n}\n\n/// `coroutine.yield([...])` — suspend the running coroutine.\n///\n/// All arguments are passed back as results of the corresponding `resume`.\n///\n/// C: `static int luaB_yield(lua_State *L)`\n/// → `return lua_yield(L, lua_gettop(L));`\n/// → `lua_yield(L,n)` is `lua_yieldk(L, n, 0, NULL)` (lua.h:316)\n///\n/// Phase A–D buffering-emulation hook: if `aux_wrap` has installed a yield\n/// buffer on the LuaState (signalling that a `coroutine.wrap` body is\n/// running synchronously on the main thread), append the arguments into\n/// that buffer and return 0 values without suspending. The wrapped\n/// function continues to run; `aux_wrap` dispenses the buffered values one\n/// per call. If no buffer is active we fall through to the faithful\n/// `lua_yieldk` translation, which on the main thread surfaces the C-Lua\n/// \"attempt to yield from outside a coroutine\" error.\npub fn co_yield(state: &mut LuaState) -> Result<usize, LuaError> {\n    if state.has_yield_buffer() {\n        let n = state.get_top();\n        let batch: Vec<LuaValue> = (1..=n).map(|i| state.value_at(i)).collect();\n        state.yield_buffer_push_batch(batch);\n        return Ok(0);\n    }\n    let n = state.get_top();\n    let r = lua_vm::do_::lua_yieldk(state, n, 0, None)?;\n    Ok(r as usize)\n}\n\n/// `coroutine.status(co)` — return a string describing `co`'s current status.\n///\n/// Returns one of `\"running\"`, `\"dead\"`, `\"suspended\"`, or `\"normal\"`.\n///\n/// C: `static int luaB_costatus(lua_State *L)`\npub fn co_status(state: &mut LuaState) -> Result<usize, LuaError> {\n    // C: lua_State *co = getco(L);\n    let co = get_co(state)?;\n    // C: lua_pushstring(L, statname[auxstatus(L, co)]);\n    let idx = aux_status(state, &co) as usize;\n    let name: &[u8] = STAT_NAMES[idx];\n    let interned = state.intern_str(name)?;\n    state.push(LuaValue::Str(interned));\n    Ok(1)\n}\n\n/// `coroutine.isyieldable([co])` — test whether a coroutine (default: current)\n/// is in a yieldable state.\n///\n/// C: `static int luaB_yieldable(lua_State *L)`\npub fn co_isyieldable(state: &mut LuaState) -> Result<usize, LuaError> {\n    let is_yieldable = if matches!(state.type_at(1), LuaType::None) {\n        state.is_yieldable()\n    } else {\n        let co = get_co(state)?;\n        let co_id = co.id;\n        let g = state.global();\n        if co_id == g.main_thread_id {\n            false\n        } else {\n            let entry = g\n                .threads\n                .get(&co_id)\n                .expect(\"thread value carries an id that must resolve in GlobalState::threads\");\n            entry.state.is_yieldable()\n        }\n    };\n    state.push(LuaValue::Bool(is_yieldable));\n    Ok(1)\n}\n\n/// `coroutine.running()` — return the current coroutine plus a boolean.\n///\n/// The boolean is `true` when the current coroutine is the main thread.\n///\n/// C: `static int luaB_corunning(lua_State *L)`\npub fn co_running(state: &mut LuaState) -> Result<usize, LuaError> {\n    // C: int ismain = lua_pushthread(L);\n    // TODO(port): push_thread pushes a Thread value for the current LuaState and\n    // returns true iff it is the main thread; Phase B wire-up needed.\n    let is_main = state.push_thread()?;\n    // C: lua_pushboolean(L, ismain);\n    state.push(LuaValue::Bool(is_main));\n    Ok(2)\n}\n\n/// `coroutine.close(co)` — close a dead or suspended coroutine.\n///\n/// Phase E-1 skeleton: the running/normal-rejection branch matches the\n/// final C-Lua behavior and lands here. Closing a suspended/dead\n/// coroutine requires running to-be-closed variables and resetting the\n/// thread; that machinery lands in slice 02d. Until then this returns\n/// an error rather than silently dropping the work.\n///\n/// C: `static int luaB_close(lua_State *L)`\npub fn co_close(state: &mut LuaState) -> Result<usize, LuaError> {\n    let co = get_co(state)?;\n    let status = aux_status(state, &co);\n    match status {\n        COS_RUN | COS_NORM => {\n            let name = if status == COS_RUN { \"running\" } else { \"normal\" };\n            Err(LuaError::runtime(format_args!(\n                \"cannot close a {} coroutine\",\n                name\n            )))\n        }\n        _ => Err(LuaError::runtime(format_args!(\n            \"coroutine.close not yet implemented for suspended/dead coroutines (Phase E-2d)\"\n        ))),\n    }\n}\n\n// ── Module entry point ────────────────────────────────────────────────────────\n\n/// Opens the `coroutine` standard library by pushing a new table containing\n/// all `coroutine.*` functions.\n///\n/// C: `LUAMOD_API int luaopen_coroutine(lua_State *L)` — `LUAMOD_API` → `pub`.\npub fn open_coroutine(state: &mut LuaState) -> Result<usize, LuaError> {\n    // C: luaL_newlib(L, co_funcs);\n    // TODO(port): state.new_lib(CO_FUNCS) creates a table from the registration\n    // slice and leaves it on the stack; Phase B wire-up needed.\n    state.new_lib(CO_FUNCS)?;\n    Ok(1)\n}\n\n// ──────────────────────────────────────────────────────────────────────────────\n// PORT STATUS\n//   source:        src/lcorolib.c  (210 lines, 12 functions)\n//   target_crate:  lua-stdlib\n//   confidence:    medium\n//   todos:         21\n//   port_notes:    2\n//   unsafe_blocks: 0\n//   notes:         All coroutine execution primitives (resume, yield, xmove,\n//                  new_thread, close_thread) are Phase E stubs that panic.\n//                  Argument-checking / result-packaging logic is faithfully\n//                  translated so Phase E can drop in real implementations.\n//                  The CO_FUNCS table type references lua_CFunction which is\n//                  resolved in Phase B.  LuaState / GcRef<LuaState> / LuaStatus\n//                  imports are all deferred to Phase B.\n// ──────────────────────────────────────────────────────────────────────────────\n","numLines":484,"startLine":1,"totalLines":484}}}
