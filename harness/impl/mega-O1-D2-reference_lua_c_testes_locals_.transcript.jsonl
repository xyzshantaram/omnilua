{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011a2TikKwQ6NN8YqHzmhhi4","type":"tool_result","content":"710\tpub(crate) fn poscall(\n711\t    state: &mut LuaState,\n712\t    ci_idx: CallInfoIdx,\n713\t    nres: i32,\n714\t) -> Result<(), LuaError> {\n715\t    // C: int wanted = ci->nresults;\n716\t    let wanted = state.get_ci(ci_idx).nresults as i32;\n717\t\n718\t    // C: if (l_unlikely(L->hookmask && !hastocloseCfunc(wanted))) rethook(L, ci, nres);\n719\t    if state.hookmask != 0 && !(wanted < LUA_MULTRET) {\n720\t        rethook(state, ci_idx, nres)?;\n721\t    }\n722\t\n723\t    // C: moveresults(L, ci->func.p, nres, wanted)\n724\t    let func_idx = state.get_ci(ci_idx).func;\n725\t    move_results(state, func_idx, nres, wanted)?;\n726\t\n727\t    // C: lua_assert(!(ci->callstatus & (CIST_HOOKED|CIST_YPCALL|CIST_FIN|CIST_TRAN|CIST_CLSRET)))\n728\t    debug_assert!(\n729\t        state.get_ci(ci_idx).callstatus\n730\t            & (CIST_HOOKED | CIST_YPCALL | CIST_FIN | CIST_TRAN | CIST_CLSRET)\n731\t            == 0\n732\t    );\n733\t\n734\t    // C: L->ci = ci->previous\n735\t    let previous = state\n736\t        .get_ci(ci_idx)\n737\t        .previous\n738\t        .expect(\"poscall: no previous call frame\");\n739\t    state.ci = previous;\n740\t    Ok(())\n741\t}\n742\t\n743\t/// Advances to the next `CallInfo` slot, allocating a new one if required.\n744\t/// Sets `state.ci` to the new frame and fills its fields.\n745\t///\n746\t/// C: `l_sinline CallInfo *prepCallInfo(lua_State *L, StkId func, int nret, int mask, StkId top)`\n747\t#[inline]\n748\tfn prep_call_info(\n749\t    state: &mut LuaState,\n750\t    func_idx: StackIdx,\n751\t    nret: i32,\n752\t    mask: u16,\n753\t    top_idx: StackIdx,\n754\t) -> Result<CallInfoIdx, LuaError> {\n755\t    // C: CallInfo *ci = L->ci = next_ci(L)\n756\t    // next_ci → L->ci->next ? L->ci->next : luaE_extendCI(L)\n757\t    let ci_idx = state.next_ci()?;\n758\t    state.ci = ci_idx;\n759\t    {\n760\t        let ci = state.get_ci_mut(ci_idx);\n761\t        ci.func = func_idx;\n762\t        ci.nresults = nret as i16;\n763\t        ci.callstatus = mask;\n764\t        ci.top = top_idx;\n765\t        ci.u = if (mask & crate::state::CIST_C) != 0 {\n766\t            crate::state::CallInfoFrame::c_default()\n767\t        } else {\n768\t            crate::state::CallInfoFrame::lua_default()\n769\t        };\n770\t    }\n771\t    Ok(ci_idx)\n772\t}\n773\t\n774\t/// Pre-call for C functions: sets up a CallInfo, fires the call hook if needed,\n775\t/// invokes the C function, and calls `poscall`.\n776\t/// Returns the number of values returned by the C function.\n777\t///\n778\t/// C: `l_sinline int precallC(lua_State *L, StkId func, int nresults, lua_CFunction f)`\n779\t#[inline]"}]},"parent_tool_use_id":null,"session_id":"7b02f0cd-a42a-42b3-ada8-8c5d45862757","uuid":"2987a339-e3c5-4557-9b3e-ee35b851534a","timestamp":"2026-05-19T03:07:15.130Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ianmclaughlin/PycharmProjects/rustExperiments/lua-rs-port/crates/lua-vm/src/do_.rs","content":"pub(crate) fn poscall(\n    state: &mut LuaState,\n    ci_idx: CallInfoIdx,\n    nres: i32,\n) -> Result<(), LuaError> {\n    // C: int wanted = ci->nresults;\n    let wanted = state.get_ci(ci_idx).nresults as i32;\n\n    // C: if (l_unlikely(L->hookmask && !hastocloseCfunc(wanted))) rethook(L, ci, nres);\n    if state.hookmask != 0 && !(wanted < LUA_MULTRET) {\n        rethook(state, ci_idx, nres)?;\n    }\n\n    // C: moveresults(L, ci->func.p, nres, wanted)\n    let func_idx = state.get_ci(ci_idx).func;\n    move_results(state, func_idx, nres, wanted)?;\n\n    // C: lua_assert(!(ci->callstatus & (CIST_HOOKED|CIST_YPCALL|CIST_FIN|CIST_TRAN|CIST_CLSRET)))\n    debug_assert!(\n        state.get_ci(ci_idx).callstatus\n            & (CIST_HOOKED | CIST_YPCALL | CIST_FIN | CIST_TRAN | CIST_CLSRET)\n            == 0\n    );\n\n    // C: L->ci = ci->previous\n    let previous = state\n        .get_ci(ci_idx)\n        .previous\n        .expect(\"poscall: no previous call frame\");\n    state.ci = previous;\n    Ok(())\n}\n\n/// Advances to the next `CallInfo` slot, allocating a new one if required.\n/// Sets `state.ci` to the new frame and fills its fields.\n///\n/// C: `l_sinline CallInfo *prepCallInfo(lua_State *L, StkId func, int nret, int mask, StkId top)`\n#[inline]\nfn prep_call_info(\n    state: &mut LuaState,\n    func_idx: StackIdx,\n    nret: i32,\n    mask: u16,\n    top_idx: StackIdx,\n) -> Result<CallInfoIdx, LuaError> {\n    // C: CallInfo *ci = L->ci = next_ci(L)\n    // next_ci → L->ci->next ? L->ci->next : luaE_extendCI(L)\n    let ci_idx = state.next_ci()?;\n    state.ci = ci_idx;\n    {\n        let ci = state.get_ci_mut(ci_idx);\n        ci.func = func_idx;\n        ci.nresults = nret as i16;\n        ci.callstatus = mask;\n        ci.top = top_idx;\n        ci.u = if (mask & crate::state::CIST_C) != 0 {\n            crate::state::CallInfoFrame::c_default()\n        } else {\n            crate::state::CallInfoFrame::lua_default()\n        };\n    }\n    Ok(ci_idx)\n}\n\n/// Pre-call for C functions: sets up a CallInfo, fires the call hook if needed,\n/// invokes the C function, and calls `poscall`.\n/// Returns the number of values returned by the C function.\n///\n/// C: `l_sinline int precallC(lua_State *L, StkId func, int nresults, lua_CFunction f)`\n#[inline]","numLines":70,"startLine":710,"totalLines":1723}}}
