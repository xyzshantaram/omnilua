{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R4mwmBp2XuZhWy9aZfjvGV","type":"tool_result","content":"778\t/// C: `l_sinline int precallC(lua_State *L, StkId func, int nresults, lua_CFunction f)`\n779\t#[inline]\n780\tfn precall_c(\n781\t    state: &mut LuaState,\n782\t    func_idx: StackIdx,\n783\t    nresults: i32,\n784\t    f: crate::state::LuaCFunction,\n785\t) -> Result<i32, LuaError> {\n786\t    // C: checkstackGCp(L, LUA_MINSTACK, func)\n787\t    state.check_stack(LUA_MINSTACK as i32)?;\n788\t    state.gc_check_step();\n789\t\n790\t    let top_idx = state.top_idx();\n791\t    // C: L->ci = ci = prepCallInfo(L, func, nresults, CIST_C, L->top.p + LUA_MINSTACK)\n792\t    let ci_idx = prep_call_info(state, func_idx, nresults, CIST_C, top_idx + LUA_MINSTACK)?;\n793\t\n794\t    // C: lua_assert(ci->top.p <= L->stack_last.p)\n795\t    debug_assert!(true /* TODO(phase-b): state.get_ci(ci_idx).top <= state.stack_last */);\n796\t\n797\t    // C: if (l_unlikely(L->hookmask & LUA_MASKCALL))\n798\t    if state.hookmask & LUA_MASKCALL != 0 {\n799\t        // C: int narg = cast_int(L->top.p - func) - 1\n800\t        let narg = (state.top_idx().0 as i32 - func_idx.0 as i32) - 1;\n801\t        hook(state, LUA_HOOKCALL, -1, 1, narg)?;\n802\t    }\n803\t\n804\t    // C: lua_unlock(L) — no-op (macros.tsv)\n805\t    // C: n = (*f)(L)\n806\t    let n = f(state)? as i32;\n807\t    // C: lua_lock(L) — no-op (macros.tsv)\n808\t\n809\t    // C: api_checknelems(L, n)\n810\t    // api_checknelems → debug_assert!(n < (top - ci_func), \"not enough elements\") (macros.tsv)\n811\t    debug_assert!(\n812\t        n <= state.top_idx().0 as i32,\n813\t        \"C function returned more values than available\"\n814\t    );\n815\t\n816\t    poscall(state, ci_idx, n)?;\n817\t    Ok(n)\n818\t}\n819\t\n820\t/// Prepares a tail call, reusing the current `CallInfo`.\n821\t/// Returns the result count for C functions, or `-1` to signal the VM that a\n822\t/// Lua function should continue executing.\n823\t///\n824\t/// C: `int luaD_pretailcall(lua_State *L, CallInfo *ci, StkId func, int narg1, int delta)`\n825\tpub(crate) fn pretailcall(\n826\t    state: &mut LuaState,\n827\t    ci_idx: CallInfoIdx,\n828\t    mut func_idx: StackIdx,\n829\t    mut narg1: i32,\n830\t    delta: i32,\n831\t) -> Result<i32, LuaError> {\n832\t    // C: retry: switch (ttypetag(s2v(func))) { ... default: goto retry; }\n833\t    loop {\n834\t        let func_val = state.get_at(func_idx).clone();\n835\t        match func_val {\n836\t            // C: case LUA_VCCL — return precallC(L, func, LUA_MULTRET, clCvalue(s2v(func))->f);\n837\t            LuaValue::Function(LuaClosure::C(ref cl)) => {\n838\t                let cfunc = state.global().c_functions[cl.func];\n839\t                return precall_c(state, func_idx, LUA_MULTRET, cfunc);\n840\t            }\n841\t            // C: case LUA_VLCF — return precallC(L, func, LUA_MULTRET, fvalue(s2v(func)));\n842\t            LuaValue::Function(LuaClosure::LightC(f)) => {\n843\t                let cfunc = state.global().c_functions[f];\n844\t                return precall_c(state, func_idx, LUA_MULTRET, cfunc);\n845\t            }\n846\t            // C: case LUA_VLCL — Lua function\n847\t            LuaValue::Function(LuaClosure::Lua(ref cl)) => {\n848\t                let proto = cl.proto.clone();\n849\t                let fsize = proto.maxstacksize as i32;\n850\t                let nfixparams = proto.numparams as i32;\n851\t\n852\t                // C: checkstackGCp(L, fsize - delta, func)\n853\t                state.check_stack(fsize - delta)?;\n854\t                state.gc_check_step();\n855\t\n856\t                // C: ci->func.p -= delta  (restore 'func' if vararg)\n857\t                {\n858\t                    let ci = state.get_ci_mut(ci_idx);\n859\t                    ci.func = StackIdx((ci.func.0 as i32 - delta) as u32);\n860\t                }\n861\t                let ci_func = state.get_ci(ci_idx).func;\n862\t\n863\t                // C: for (i = 0; i < narg1; i++) setobjs2s(L, ci->func.p + i, func + i)\n864\t                for i in 0..narg1 {\n865\t                    let src = state.get_at(func_idx + i as i32).clone();\n866\t                    state.set_at(ci_func + i as i32, src);\n867\t                }"}]},"parent_tool_use_id":null,"session_id":"7b02f0cd-a42a-42b3-ada8-8c5d45862757","uuid":"442d7b0b-a7b8-457d-8d56-39cc329ce985","timestamp":"2026-05-19T03:06:56.184Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/ianmclaughlin/PycharmProjects/rustExperiments/lua-rs-port/crates/lua-vm/src/do_.rs","content":"/// C: `l_sinline int precallC(lua_State *L, StkId func, int nresults, lua_CFunction f)`\n#[inline]\nfn precall_c(\n    state: &mut LuaState,\n    func_idx: StackIdx,\n    nresults: i32,\n    f: crate::state::LuaCFunction,\n) -> Result<i32, LuaError> {\n    // C: checkstackGCp(L, LUA_MINSTACK, func)\n    state.check_stack(LUA_MINSTACK as i32)?;\n    state.gc_check_step();\n\n    let top_idx = state.top_idx();\n    // C: L->ci = ci = prepCallInfo(L, func, nresults, CIST_C, L->top.p + LUA_MINSTACK)\n    let ci_idx = prep_call_info(state, func_idx, nresults, CIST_C, top_idx + LUA_MINSTACK)?;\n\n    // C: lua_assert(ci->top.p <= L->stack_last.p)\n    debug_assert!(true /* TODO(phase-b): state.get_ci(ci_idx).top <= state.stack_last */);\n\n    // C: if (l_unlikely(L->hookmask & LUA_MASKCALL))\n    if state.hookmask & LUA_MASKCALL != 0 {\n        // C: int narg = cast_int(L->top.p - func) - 1\n        let narg = (state.top_idx().0 as i32 - func_idx.0 as i32) - 1;\n        hook(state, LUA_HOOKCALL, -1, 1, narg)?;\n    }\n\n    // C: lua_unlock(L) — no-op (macros.tsv)\n    // C: n = (*f)(L)\n    let n = f(state)? as i32;\n    // C: lua_lock(L) — no-op (macros.tsv)\n\n    // C: api_checknelems(L, n)\n    // api_checknelems → debug_assert!(n < (top - ci_func), \"not enough elements\") (macros.tsv)\n    debug_assert!(\n        n <= state.top_idx().0 as i32,\n        \"C function returned more values than available\"\n    );\n\n    poscall(state, ci_idx, n)?;\n    Ok(n)\n}\n\n/// Prepares a tail call, reusing the current `CallInfo`.\n/// Returns the result count for C functions, or `-1` to signal the VM that a\n/// Lua function should continue executing.\n///\n/// C: `int luaD_pretailcall(lua_State *L, CallInfo *ci, StkId func, int narg1, int delta)`\npub(crate) fn pretailcall(\n    state: &mut LuaState,\n    ci_idx: CallInfoIdx,\n    mut func_idx: StackIdx,\n    mut narg1: i32,\n    delta: i32,\n) -> Result<i32, LuaError> {\n    // C: retry: switch (ttypetag(s2v(func))) { ... default: goto retry; }\n    loop {\n        let func_val = state.get_at(func_idx).clone();\n        match func_val {\n            // C: case LUA_VCCL — return precallC(L, func, LUA_MULTRET, clCvalue(s2v(func))->f);\n            LuaValue::Function(LuaClosure::C(ref cl)) => {\n                let cfunc = state.global().c_functions[cl.func];\n                return precall_c(state, func_idx, LUA_MULTRET, cfunc);\n            }\n            // C: case LUA_VLCF — return precallC(L, func, LUA_MULTRET, fvalue(s2v(func)));\n            LuaValue::Function(LuaClosure::LightC(f)) => {\n                let cfunc = state.global().c_functions[f];\n                return precall_c(state, func_idx, LUA_MULTRET, cfunc);\n            }\n            // C: case LUA_VLCL — Lua function\n            LuaValue::Function(LuaClosure::Lua(ref cl)) => {\n                let proto = cl.proto.clone();\n                let fsize = proto.maxstacksize as i32;\n                let nfixparams = proto.numparams as i32;\n\n                // C: checkstackGCp(L, fsize - delta, func)\n                state.check_stack(fsize - delta)?;\n                state.gc_check_step();\n\n                // C: ci->func.p -= delta  (restore 'func' if vararg)\n                {\n                    let ci = state.get_ci_mut(ci_idx);\n                    ci.func = StackIdx((ci.func.0 as i32 - delta) as u32);\n                }\n                let ci_func = state.get_ci(ci_idx).func;\n\n                // C: for (i = 0; i < narg1; i++) setobjs2s(L, ci->func.p + i, func + i)\n                for i in 0..narg1 {\n                    let src = state.get_at(func_idx + i as i32).clone();\n                    state.set_at(ci_func + i as i32, src);\n                }","numLines":90,"startLine":778,"totalLines":1723}}}
